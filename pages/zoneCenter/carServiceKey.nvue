<template>
	<view class="container" :style="containerStyle" @touchmove.prevent="handleTouchMove">
		<view class="select-region">
			<view class="select-vehicle" @tap="handleJumpVehicle" v-if="!vehicle_info?.sn">
				<text>请选择车辆</text>
				<image src="/static/images/right_1.png" class="select-vehicle-image"></image>
			</view>
			<view v-else>
				<view
					style="display: flex;flex-direction: row;justify-content: space-between;width: 730rpx;border-bottom: 1px solid #f0f0f0;padding: 20rpx; font-size: 26rpx;align-items: center;">
					<view style="display: flex;flex-direction: row;gap: 20rpx;align-items: center;">
						<view style="display: flex;flex-direction: row; margin-right: 4rpx;align-items: center;">
							<image src="/static/public/car_01.png" style="width: 40rpx;height: 40rpx;"></image>
							<text style="font-weight: bold;">{{vehicle_info?.platenumber}}</text>
						</view>
						<view
							style="background-color: aliceblue;border-radius: 5rpx;padding: 0 8rpx;margin-right: 4rpx;align-items: center;">
							<text style="color: #2440b3;">
								{{vehicle_info.vehicleSerialName||'-'}}{{vehicle_info.vehicleModeName||''}}</text>
						</view>
						<view>
							{{vehicle_info.sn ?'3':vehicle_info.sn===null?'2':'-'}}
						</view>
					</view>
					<view style="display: flex;flex-direction: row;align-items: center;" @tap="handleJumpVehicle">
						<text style="font-size: 28rpx;color: #2440b3;">3</text>
						<image src="/static/public/right.png" style="width: 28rpx;height: 28rpx;"></image>
					</view>
				</view>
				<view
					style="display: flex;width: 730rpx;flex-direction: row;justify-content: space-between;padding: 20rpx;">
					<view>
						车架号：{{vehicle_info?.vin||'-'}}
					</view>
					<view>设备号：{{vehicle_info?.sn||'-'}}</view>
				</view>
			</view>
		</view>

		<view class="web-view-container">
			<web-view ref="webview" @onPostMessage="handlePostMessage" :src="webUrlWithTimestamp"
				:style="{ height: contentHeight + 'px' }">
			</web-view>
		</view>
	</view>
</template>

<script>
	import {
		info_screen
	} from '@/utils/scheme/screen.js'
	import {
		u_getAllCarPoisiton,
		u_operation
	} from '@/api'
	import 'url-search-params-polyfill';

	// 常量定义
	const DATA_SEND_INTERVAL = 2000;
	const NAVBAR_HEIGHT = {
		ios: 49,
		android: 44,
		default: 44
	};

	export default {
		components: {
		
		},

		data: () => ({
			screenInfo: {},
			nowTimestamp: Date.now(),
			vehicle_info: {},
			info: [],
			isLoading: false,
			sendDataTimeout: null,
			
		}),

		computed: {
			containerStyle() {
				return {
					height: `${this.screenInfo.screenHeight || 667}px`
				};
			},

			webUrlWithTimestamp() {
				return `/hybrid/html/sendKey.html?nowTime=${this.nowTimestamp}`;
			},

			statusBarHeight() {
				return this.screenInfo.statusBarHeight || 0;
			},

			navBarHeight() {
				return NAVBAR_HEIGHT[this.screenInfo.platform] || NAVBAR_HEIGHT.default;
			},

			contentHeight() {
				const {
					screenHeight
				} = this.screenInfo;
				return screenHeight - (this.statusBarHeight + this.navBarHeight + (!this.vehicle_info?.platenumber ? 60 :
					100));
			}
		},

		onLoad(options) {
			console.log(options,'2222')
			this.vehicle_info = JSON.parse(options?.datails || '{}');
			this.initialScreenInfo();
		},

		async onShow() {
			this.isLoading = true;
			

			try {
				this.nowTimestamp = Date.now();
				await this.initSearchLink();
			} catch (error) {
				console.error('数据初始化失败:', error);
				uni.showToast({
					title: '数据加载失败',
					icon: 'none'
				});
			} finally {
				this.isLoading = false;
			}
			this.handleGetCurrentLanguage()
		},

		onUnload() {
			this.clearSendDataTimer();
		},

		methods: {
			handleGetCurrentLanguage() {
				let currentLang = uni.getStorageSync('lang') || 'zh-CN';
				
			},
			// 初始化屏幕信息
			async initialScreenInfo() {
				try {
					this.screenInfo = await info_screen();
					if (process.env.NODE_ENV === 'development') {
						console.log('Screen info:', this.screenInfo);
					}
				} catch (error) {
					console.error('[ScreenInfo] 获取屏幕信息失败:', error);
					uni.showToast({
						title: '设备信息获取失败',
						icon: 'none'
					});
				}
			},

			// 获取车辆位置数据
			async initSearchLink() {
				try {
					const res = await u_getAllCarPoisiton();
					this.info = res.content || [];
					this.sendDataToWebviewDebounced();
				} catch (error) {
					console.error('车辆位置请求失败:', error);
				}
			},

			// 防抖发送数据
			sendDataToWebviewDebounced() {
				let currentLang = uni.getStorageSync('lang') || 'zh-CN';
				this.clearSendDataTimer();
				this.sendDataTimeout = setTimeout(() => {
					this.sendDataToWebview({
						type: 'elctrncky',
						payload: this.info,
						vehicle_info: this.vehicle_info,
						lang: currentLang
					});
				}, DATA_SEND_INTERVAL);
			},

			// 清理定时器
			clearSendDataTimer() {
				if (this.sendDataTimeout) {
					clearTimeout(this.sendDataTimeout);
					this.sendDataTimeout = null;
				}
			},

			// 向Webview发送数据
			sendDataToWebview(data) {
				console.log('222]]]',data)
				const payload = JSON.stringify(data);
				const jsStr = `window.postMessage(${payload}, '*')`;

				// APP端处理
				// #ifdef APP-PLUS
				this.$refs.webview?.evalJS(jsStr);
				// #endif

				// H5端处理
				// #ifdef H5
				const iframe = document.querySelector('web-view iframe');
				iframe?.contentWindow?.postMessage(data, '*');
				// #endif
			},

			// 页面跳转
			handleJumpVehicle() {
		
				uni.redirectTo({
					url: `/pages/zoneCenter/carKeyConfig?source=/pages/zoneCenter/carServiceKey`
				});
			},

			// 消息处理
			handlePostMessage(evt) {
				const messageData = evt?.detail?.data?.[0] || {};
				const {
					source
				} = messageData;
				if (!source) {
					console.warn('Received message without type:', evt);
					return;
				}
				// 使用策略模式替代多重 if 判断
				const ACTION_HANDLERS = {
					3: () => {
						console.log('开锁操作');
						this.handleVehicle(source);
					},
					1: () => {
						console.log('关锁操作');
						this.handleVehicle(source);
					},
					5: () => {
						console.log('寻车操作');
						this.handleVehicle(source);
					},
					8: () => {
						console.log('风控拦截');
						this.handleVehicle(source);
					},
					6: () => {
						console.log('取消拦截');
						this.handleVehicle(source);
					}
				};

				// 执行对应的处理函数
				const handler = ACTION_HANDLERS[source];
				if (handler) {
					handler();
				} else {
					console.warn(`未处理的 message 类型: ${source}`, messageData);
				}

				const targetSn = evt.detail.data[0]?.plateNumber;
				if (!targetSn) return;

				const matchedItem = this.info.find(item => item.plateNumber === targetSn);
				console.log('matchedItem', matchedItem)
				if (matchedItem) {
					this.vehicle_info = matchedItem;
				}
			},
			async handleVehicle(evt) {
				try {
					const controlType = evt;
					const requestParam = {
						sn: this.vehicle_info?.sn,
						operationType: controlType,
						_timestamp: Date.now()	
					};
					const res = await u_operation(requestParam)
					uni.showToast({
						title: res.msg,
						icon: 'none',
						duration: 2000,
					});

				} catch (error) {}
			},
		}
	}
</script>

<style>
	/* ===== 基础布局 ===== */
	.container {
		width: 750rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		
		background-size: cover;
	}

	.select-region {
		width: 740rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10rpx;
		border-radius: 6rpx 10rpx;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
		background-color: #fff;
		margin-bottom: 5rpx;
	}

	.select-vehicle-image {
		width: 28rpx;
		height: 28rpx;
	}

	.web-view-container {
		width: 740rpx;
	}

	.select-vehicle {
		width: 720rpx;
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		border-radius: 8px;
		height: 50px;
		background-color: aliceblue;
		color: #333;
	}
</style>