<template>
	<view class="container" :style="containerStyle" @touchmove.prevent="handleTouchMove">
		<view class="select-region">
			<view class="select-vehicle" @tap="handleJumpVehicle" v-if="!vehicle_info?.sn">
				<text>请选择车辆</text>
				<image src="/static/images/right_1.png" class="select-vehicle-image"></image>
			</view>
			<view v-else>
				<view class="vehicle-info-main">
					<view class="vehicle-info-left">
						<view class="vehicle-plate-wrapper">
							<image src="/static/images/01.png" class="vehicle-icon"></image>
							<text class="vehicle-plate-text">{{vehicle_info?.platenumber}}</text>
						</view>
						<view class="vehicle-type-tag">
							<text class="vehicle-type-text">
								{{vehicle_info.vehicleSerialName||'-'}}{{vehicle_info.vehicleModeName||''}}
							</text>
						</view>
					</view>
					<view class="vehicle-edit-btn" @tap="handleJumpVehicle">
						<text class="vehicle-edit-text">重新选择</text>
						<image src="/static/images/right_1.png" class="right-arrow-icon"></image>
					</view>
				</view>
				<view class="vehicle-vin-device">
					<view>车架号：{{vehicle_info?.vin||'-'}}</view>
					<view>设备号：{{vehicle_info?.sn||'-'}}</view>
				</view>
			</view>
		</view>

		<!-- 日期区间选择弹窗（悬浮上层） -->
		<view class="picker-mask" @click="closePicker" v-if="showPicker">
			<view class="picker-panel" @click.stop="">
				<view class="panel-body">
					<view class="panel-title">请选择开始和结束日期</view>

					<!-- 开始日期 -->
					<picker mode="date" :value="startDate" @change="onStartChange">
						<view class="picker-item">
							<text>开始日期</text>
							<text class="val">{{ startDate || '请选择' }}</text>
						</view>
					</picker>

					<!-- 结束日期 -->
					<picker mode="date" :value="endDate" @change="onEndChange">
						<view class="picker-item">
							<text>结束日期</text>
							<text class="val">{{ endDate || '请选择' }}</text>
						</view>
					</picker>

					<!-- 按钮组 -->
					<view class="btn-group">
						<text class="btn cancel" @click="closePicker">取消</text>
						<text class="btn confirm" @click="confirmPicker">确认</text>
					</view>
				</view>
			</view>
		</view>

		<view class="web-view-container">
			<web-view ref="webview" @onPostMessage="handlePostMessage" :src="webUrlWithTimestamp"
				:style="{ height: contentHeight + 'px' }"></web-view>
		</view>
	</view>
</template>

<script>
	import {
		info_screen
	} from '@/utils/scheme/screen.js'
	import {
		u_getAllCarPoisiton,
		u_operation
	} from '@/api'
	import 'url-search-params-polyfill';

	// 常量定义
	const DATA_SEND_INTERVAL = 2000;
	const NAVBAR_HEIGHT = {
		ios: 49,
		android: 44,
		default: 44
	};

	export default {
		components: {},

		data: () => ({
			screenInfo: {},
			nowTimestamp: Date.now(),
			vehicle_info: {},
			info: [],
			isLoading: false,
			sendDataTimeout: null,
			showPicker: false,
			startDate: '',
			endDate: '',
			lat: []
		}),

		computed: {
			containerStyle() {
				return {
					height: `${this.screenInfo.windowHeight || 667}px`
				};
			},

			webUrlWithTimestamp() {
				return `/hybrid/html/trajectory.html?nowTime=${this.nowTimestamp}`;
			},

			statusBarHeight() {
				return this.screenInfo.statusBarHeight || 0;
			},

			navBarHeight() {
				return NAVBAR_HEIGHT[this.screenInfo.platform] || NAVBAR_HEIGHT.default;
			},

			contentHeight() {
				const {
					screenHeight
				} = this.screenInfo;
				return screenHeight - (this.statusBarHeight + this.navBarHeight + (!this.vehicle_info?.platenumber ? 60 :
					100));
			}
		},

		onLoad(options) {
			console.log(options, '2222')
			this.vehicle_info = JSON.parse(options?.datails || '{}');
			this.initialScreenInfo();
		},

		async onShow() {
			this.isLoading = true;

			try {
				this.nowTimestamp = Date.now();
				await this.initSearchLink();
			} catch (error) {
				console.error('数据初始化失败:', error);
				uni.showToast({
					title: '数据加载失败',
					icon: 'none'
				});
			} finally {
				this.isLoading = false;
			}
			this.handleGetCurrentLanguage()
		},

		onUnload() {
			this.clearSendDataTimer();
		},

		methods: {
			handleGetCurrentLanguage() {
				let currentLang = uni.getStorageSync('lang') || 'zh-CN';
			},

			// 初始化屏幕信息
			async initialScreenInfo() {
				try {
					this.screenInfo = await info_screen();
					if (process.env.NODE_ENV === 'development') {
						console.log('Screen info:', this.screenInfo);
					}
				} catch (error) {
					console.error('[ScreenInfo] 获取屏幕信息失败:', error);
					uni.showToast({
						title: '设备信息获取失败',
						icon: 'none'
					});
				}
			},

			// 获取车辆位置数据
			async initSearchLink() {
				try {
					const res = await u_getAllCarPoisiton();
					this.info = res.content || [];
					this.sendDataToWebviewDebounced();
				} catch (error) {
					console.error('车辆位置请求失败:', error);
				}
			},

			// 防抖发送数据
			sendDataToWebviewDebounced() {
				let currentLang = uni.getStorageSync('lang') || 'zh-CN';
				this.clearSendDataTimer();
				this.sendDataTimeout = setTimeout(() => {
					this.sendDataToWebview({
						type: 'elctrncky',
						payload: this.info,
						vehicle_info: this.vehicle_info,
						lat: this.lat,
						lang: currentLang
					});
				}, DATA_SEND_INTERVAL);
			},

			// 清理定时器
			clearSendDataTimer() {
				if (this.sendDataTimeout) {
					clearTimeout(this.sendDataTimeout);
					this.sendDataTimeout = null;
				}
			},

			// 向Webview发送数据
			sendDataToWebview(data) {
				console.log('222]]]', data)
				const payload = JSON.stringify(data);
				const jsStr = `window.postMessage(${payload}, '*')`;

				// APP端处理
				// #ifdef APP-PLUS
				this.$refs.webview?.evalJS(jsStr);
				// #endif

				// H5端处理
				// #ifdef H5
				const iframe = document.querySelector('web-view iframe');
				iframe?.contentWindow?.postMessage(data, '*');
				// #endif
			},

			// 页面跳转
			handleJumpVehicle() {
				uni.redirectTo({
					url: `/pages/zoneCenter/carKeyConfig?source=/pages/zoneCenter/trajectory`
				});
			},

			handleDate(e) {
				if (this.vehicle_info?.sn) {
					// 打开日期选择器
					this.showPicker = true;
				} else {
					uni.showToast({
						title: '请先选择车辆',
						icon: 'none'
					})
				}
			},

			// 消息处理
			handlePostMessage(evt) {
				const messageData = evt?.detail?.data?.[0] || {};
				const {
					source
				} = messageData;

				if (!source) {
					console.warn('Received message without type:', evt);
					return;
				}
				// 使用策略模式替代多重 if 判断
				const ACTION_HANDLERS = {
					3: () => {
						console.log('开锁操作');
						this.handleVehicle(source);
					},
					1: () => {
						console.log('关锁操作');
						this.handleVehicle(source);
					},
					5: () => {
						console.log('寻车操作');
						this.handleVehicle(source);
					},
					8: () => {
						console.log('风控拦截');
						this.handleVehicle(source);
					},
					6: () => {
						console.log('取消拦截');
						this.handleVehicle(source);
					},
					100: () => {
						console.log('轨迹查询');
						this.handleDate(source);
					}
				};

				// 执行对应的处理函数
				const handler = ACTION_HANDLERS[source];
				if (handler) {
					handler();
				} else {
					console.warn(`未处理的 message 类型: ${source}`, messageData);
				}

				const targetSn = evt.detail.data[0]?.plateNumber;
				if (!targetSn) return;

				const matchedItem = this.info.find(item => item.plateNumber === targetSn);
				console.log('matchedItem', matchedItem)
				if (matchedItem) {
					this.vehicle_info = matchedItem;
				}
			},

			async handleVehicle(evt) {
				try {
					const controlType = evt;
					const requestParam = {
						sn: this.vehicle_info?.sn,
						operationType: controlType,
						_timestamp: Date.now()
					};
					const res = await u_operation(requestParam)
					uni.showToast({
						title: res.msg,
						icon: 'none',
						duration: 2000,
					});

				} catch (error) {}
			},

			// 触摸移动事件
			handleTouchMove() {},

			// 关闭日期选择器
			closePicker() {
				this.showPicker = false;
			},

			// 确认日期选择
			confirmPicker() {
				if (!this.startDate || !this.endDate) {
					uni.showToast({
						title: '请选择完整的日期区间',
						icon: 'none'
					});
					return;
				}
				// 关闭弹窗并可后续扩展日期提交逻辑
				this.showPicker = false;
				this.lat = [{
					lat: 12,
					lat1: 223
				}]
				this.sendDataToWebviewDebounced();
				console.log('选择的日期:', this.startDate, this.endDate);
			},

			// 开始日期改变
			onStartChange(e) {
				this.startDate = e.detail.value;
			},

			// 结束日期改变
			onEndChange(e) {
				this.endDate = e.detail.value;
			}
		}
	}
</script>

<style>
	/* ===== 基础布局 ===== */
	.container {
		width: 750rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		background-size: cover;
	}

	.select-region {
		width: 740rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10rpx;
		border-radius: 6rpx 10rpx;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
		background-color: #fff;
		margin-bottom: 5rpx;
	}

	.select-vehicle-image {
		width: 28rpx;
		height: 28rpx;
	}

	.web-view-container {
		width: 740rpx;
	}

	.select-vehicle {
		width: 720rpx;
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		border-radius: 8px;
		height: 50px;
		background-color: aliceblue;
		color: #333;
	}

	/* 车辆信息样式 */
	.vehicle-info-main {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		width: 730rpx;
		border-bottom: 1px solid #f0f0f0;
		padding: 20rpx;
		font-size: 26rpx;
		align-items: center;
	}

	.vehicle-info-left {
		display: flex;
		flex-direction: row;
		gap: 20rpx;
		align-items: center;
	}

	.vehicle-plate-wrapper {
		display: flex;
		flex-direction: row;
		margin-right: 4rpx;
		align-items: center;
	}

	.vehicle-icon {
		width: 40rpx;
		height: 40rpx;
	}

	.vehicle-plate-text {
		font-weight: bold;
	}

	.vehicle-type-tag {
		background-color: aliceblue;
		border-radius: 5rpx;
		padding: 0 8rpx;
		margin-right: 4rpx;
		align-items: center;
	}

	.vehicle-type-text {
		color: #2440b3;
	}

	.vehicle-edit-btn {
		display: flex;
		flex-direction: row;
		align-items: center;
	}

	.vehicle-edit-text {
		font-size: 28rpx;
		color: #2440b3;
	}

	.right-arrow-icon {
		width: 28rpx;
		height: 28rpx;
	}

	.vehicle-vin-device {
		display: flex;
		width: 730rpx;
		flex-direction: row;
		justify-content: space-between;
		padding: 20rpx;
	}

	/* 遮罩层（全屏悬浮） */
	.picker-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
	}

	/* 选择面板 - 居中、宽度100%、高级样式 */
	.picker-panel {
		min-width: 600rpx;
		background: #ffffff;
		border-radius: 24rpx;
		box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
		overflow: hidden;
	}

	/* 标题 */
	.panel-title {
		text-align: center;
		font-size: 32rpx;
		font-weight: 500;
		color: #333;
		margin-bottom: 20rpx;
	}

	/* 内容区 */
	.panel-body {
		padding: 40rpx 30rpx;
	}

	/* 选择项 */
	.picker-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 28rpx 20rpx;
		margin: 10rpx 0;
		background: #f7f8fa;
		border-radius: 16rpx;
		font-size: 28rpx;
		color: #555;
	}

	.picker-item .val {
		color: #1677ff;
		font-weight: 500;
	}

	/* 按钮组 */
	.btn-group {
		display: flex;
		justify-content: space-between;
		flex-direction: row;
		margin-top: 40rpx;
	}

	.btn {
		flex: 1;
		text-align: center;
		padding: 24rpx;
		border-radius: 16rpx;
		font-size: 28rpx;
		font-weight: 500;
	}

	/* 取消按钮 */
	.btn.cancel {
		background: #f5f5f5;
		color: #666;
		margin-right: 5rpx;
	}

	/* 确认按钮 */
	.btn.confirm {
		margin-left: 5rpx;
		background: #1677ff;
		color: #fff;
	}
</style>