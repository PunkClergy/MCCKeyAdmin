<template>
	<!-- 只在 不显示弹窗 时阻止滑动，显示弹窗时不阻止 -->
	<view class="container" :style="containerStyle" @touchmove.prevent="!showPicker">
		<view class="select-region">
			<view class="select-vehicle" @tap="handleJumpVehicle" v-if="!vehicle_info?.sn">
				<text>{{ tips.PleaseSelectCar[lang] }}</text>
				<image src="/static/images/right_1.png" class="select-vehicle-image"></image>
			</view>
			<view v-else>
				<view class="vehicle-info-main">
					<view class="vehicle-info-left">
						<view class="vehicle-plate-wrapper">
							<image src="/static/images/01.png" class="vehicle-icon"></image>
							<text class="vehicle-plate-text">{{vehicle_info?.platenumber}}</text>
						</view>
						<view class="vehicle-type-tag">
							<text class="vehicle-type-text">
								{{vehicle_info.vehicleSerialName||tips.NoData[lang]}}{{vehicle_info.vehicleModeName||''}}
							</text>
						</view>
					</view>
					<view class="vehicle-edit-btn" @tap="handleJumpVehicle">
						<text class="vehicle-edit-text">{{ tips.ReSelect[lang] }}</text>
						<image src="/static/images/right_1.png" class="right-arrow-icon"></image>
					</view>
				</view>
				<view class="vehicle-vin-device">
					<view>{{ tips.VIN[lang] }}：{{vehicle_info?.vin||tips.NoData[lang]}}</view>
					<view>{{ tips.DeviceID[lang] }}：{{vehicle_info?.sn||tips.NoData[lang]}}</view>
				</view>
			</view>
		</view>

		<view class="picker-mask" @click="closePicker" v-if="showPicker">
			<view class="picker-panel" @click.stop="">
				<view class="panel-body">
					<view class="panel-title">{{ tips.PleaseSelectDateRange[lang] }}</view>

					<picker mode="date" :value="startDate" @change="onStartChange">
						<view class="picker-item">
							<text>{{ tips.StartDate[lang] }}</text>
							<text class="val">{{ startDate || tips.PleaseSelect[lang] }}</text>
						</view>
					</picker>

					<picker mode="date" :value="endDate" @change="onEndChange">
						<view class="picker-item">
							<text>{{ tips.EndDate[lang] }}</text>
							<text class="val">{{ endDate || tips.PleaseSelect[lang] }}</text>
						</view>
					</picker>

					<view class="btn-group">
						<text class="btn cancel" @click="closePicker">{{ tips.Cancel[lang] }}</text>
						<text class="btn confirm" @click="confirmPicker">{{ tips.Confirm[lang] }}</text>
					</view>
				</view>
			</view>
		</view>

		<view class="web-view-container">
			<web-view ref="webview" @onPostMessage="handlePostMessage" :src="webUrlWithTimestamp"
				:style="{ height: contentHeight + 'px' }"></web-view>
		</view>
	</view>
</template>

<script>
	import {
		tips
	} from '@/utils/langtips.js'
	import {
		titles
	} from '@/utils/langtitle.js'
	import {
		info_screen
	} from '@/utils/scheme/screen.js'
	import {
		u_getAllCarPoisiton,
		u_operation,
		u_getTrackPlayback
	} from '@/api'
	import 'url-search-params-polyfill';
	const DATA_SEND_INTERVAL = 2000;
	const NAVBAR_HEIGHT = {
		ios: 49,
		android: 44,
		default: 44
	};

	export default {
		components: {},

		data: () => ({
			lang: 'zhCn',
			tips: tips,

			screenInfo: {},
			nowTimestamp: Date.now(),
			vehicle_info: {},
			info: [],
			sendDataTimeout: null,
			showPicker: false,
			startDate: '',
			endDate: '',
			lat: []
		}),

		computed: {
			containerStyle() {
				return {
					height: `${this.screenInfo.windowHeight || 667}px`
				};
			},

			webUrlWithTimestamp() {
				return `/hybrid/html/trajectory.html?nowTime=${this.nowTimestamp}`;
			},

			statusBarHeight() {
				return this.screenInfo.statusBarHeight || 0;
			},

			navBarHeight() {
				return NAVBAR_HEIGHT[this.screenInfo.platform] || NAVBAR_HEIGHT.default;
			},

			contentHeight() {
				const {
					screenHeight
				} = this.screenInfo;
				return screenHeight - (this.statusBarHeight + this.navBarHeight + (!this.vehicle_info?.platenumber ? 60 :
					100));
			}
		},

		onLoad(options) {
			this.vehicle_info = JSON.parse(options?.datails || '{}');
			this.initialScreenInfo();
		},

		async onShow() {
			this.lang = uni.getStorageSync('language') || 'zhCn'
			uni.setNavigationBarTitle({
				title: titles['zoneCenter/trajectory'][this.lang]
			})

			try {
				this.nowTimestamp = Date.now();
				await this.initSearchLink();
			} catch (error) {
				console.error('数据初始化失败:', error);
				uni.showToast({
					title: this.tips.DataLoadFailed[this.lang],
					icon: 'none'
				});
			}
		},

		onUnload() {
			this.clearSendDataTimer();
		},

		methods: {
			async initialScreenInfo() {
				try {
					this.screenInfo = await info_screen();
				} catch (error) {
					console.error('[ScreenInfo] 获取屏幕信息失败:', error);
					uni.showToast({
						title: this.tips.DeviceInfoFailed[this.lang],
						icon: 'none'
					});
				}
			},

			async initSearchLink() {
				try {
					const res = await u_getAllCarPoisiton();
					this.info = res.content || [];
					this.sendDataToWebviewDebounced();
				} catch (error) {
					console.error('车辆位置请求失败:', error);
				}
			},

			sendDataToWebviewDebounced() {
				this.clearSendDataTimer();
				this.sendDataTimeout = setTimeout(() => {
					this.sendDataToWebview({
						type: 'elctrncky',
						payload: this.info,
						vehicle_info: this.vehicle_info,
						lat: this.lat,
						lang: this.lang
					});
				}, DATA_SEND_INTERVAL);
			},

			clearSendDataTimer() {
				if (this.sendDataTimeout) {
					clearTimeout(this.sendDataTimeout);
					this.sendDataTimeout = null;
				}
			},

			sendDataToWebview(data) {
				const payload = JSON.stringify(data);
				const jsStr = `window.postMessage(${payload}, '*')`;

				// #ifdef APP-PLUS
				this.$refs.webview?.evalJS(jsStr);
				// #endif

				// #ifdef H5
				const iframe = document.querySelector('web-view iframe');
				iframe?.contentWindow?.postMessage(data, '*');
				// #endif
			},

			handleJumpVehicle() {
				uni.redirectTo({
					url: `/pages/zoneCenter/carKeyConfig?source=/pages/zoneCenter/trajectory`
				});
			},

			handleDate() {
				if (this.vehicle_info?.sn) {
					this.showPicker = true;
				} else {
					uni.showToast({
						title: this.tips.PleaseSelectCarFirst[this.lang],
						icon: 'none'
					})
				}
			},

			handlePostMessage(evt) {
				const messageData = evt?.detail?.data?.[0] || {};
				const {
					source
				} = messageData;
				if (!source) return;

				const ACTION_HANDLERS = {
					3: () => this.handleVehicle(source),
					1: () => this.handleVehicle(source),
					5: () => this.handleVehicle(source),
					8: () => this.handleVehicle(source),
					6: () => this.handleVehicle(source),
					100: () => this.handleDate()
				};

				const handler = ACTION_HANDLERS[source];
				if (handler) handler();

				const targetSn = evt.detail.data[0]?.plateNumber;
				if (!targetSn) return;

				const matchedItem = this.info.find(item => item.plateNumber === targetSn);
				if (matchedItem) this.vehicle_info = matchedItem;
			},

			async handleVehicle(evt) {
				try {
					const res = await u_operation({
						sn: this.vehicle_info?.sn,
						operationType: evt,
						_timestamp: Date.now()
					});
					uni.showToast({
						title: res.msg,
						icon: 'none',
						duration: 2000
					});
				} catch (error) {}
			},

			closePicker() {
				this.showPicker = false;
			},

			async confirmPicker() {
				if (!this.startDate || !this.endDate) {
					uni.showToast({
						title: this.tips.PleaseSelectFullDate[this.lang],
						icon: 'none'
					});
					return;
				}

				if (!this.vehicle_info?.sn) {
					uni.showToast({
						title: this.tips.PleaseSelectCarFirst[this.lang],
						icon: 'none'
					});
					return;
				}

				const params = {
					sn: this.vehicle_info.sn,
					startDate: `${this.startDate} 00:00`,
					endDate: `${this.endDate} 23:59`
				};

				try {
					const responeInfo = await u_getTrackPlayback(params);
					if (responeInfo?.code === 1000) {
						const trackList = responeInfo?.content || [];
						this.lat = trackList.map(item => ({
							lat: item.latitude,
							lng: item.longitude,
							gpstime: item.gpstime
						}));

						this.showPicker = false;
						this.sendDataToWebviewDebounced();
						uni.showToast({
							title: this.tips.TrackLoadSuccess[this.lang],
							icon: 'success'
						});
					} else {
						uni.showToast({
							title: responeInfo?.msg || this.tips.NoTrackData[this.lang],
							icon: 'none'
						});
					}
				} catch (err) {
					console.error('轨迹请求失败：', err);
					uni.showToast({
						title: this.tips.TrackRequestFailed[this.lang],
						icon: 'none'
					});
				}
			},

			onStartChange(e) {
				this.startDate = e.detail.value;
			},
			onEndChange(e) {
				this.endDate = e.detail.value;
			}
		}
	}
</script>

<style>
	.container {
		width: 750rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		background-size: cover;
	}

	.select-region {
		width: 740rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10rpx;
		border-radius: 6rpx 10rpx;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
		background-color: #fff;
		margin-bottom: 5rpx;
	}

	.select-vehicle-image {
		width: 28rpx;
		height: 28rpx;
	}

	.web-view-container {
		width: 740rpx;
	}

	.select-vehicle {
		width: 720rpx;
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		border-radius: 8px;
		height: 50px;
		background-color: aliceblue;
		color: #333;
	}

	.vehicle-info-main {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		width: 730rpx;
		border-bottom: 1px solid #f0f0f0;
		padding: 20rpx;
		font-size: 26rpx;
		align-items: center;
	}

	.vehicle-info-left {
		display: flex;
		flex-direction: row;
		gap: 20rpx;
		align-items: center;
	}

	.vehicle-plate-wrapper {
		display: flex;
		flex-direction: row;
		margin-right: 4rpx;
		align-items: center;
	}

	.vehicle-icon {
		width: 40rpx;
		height: 40rpx;
	}

	.vehicle-plate-text {
		font-weight: bold;
	}

	.vehicle-type-tag {
		background-color: aliceblue;
		border-radius: 5rpx;
		padding: 0 8rpx;
		margin-right: 4rpx;
		align-items: center;
	}

	.vehicle-type-text {
		color: #2440b3;
	}

	.vehicle-edit-btn {
		display: flex;
		flex-direction: row;
		align-items: center;
	}

	.vehicle-edit-text {
		font-size: 28rpx;
		color: #2440b3;
	}

	.right-arrow-icon {
		width: 28rpx;
		height: 28rpx;
	}

	.vehicle-vin-device {
		display: flex;
		width: 730rpx;
		flex-direction: row;
		justify-content: space-between;
		padding: 20rpx;
	}

	.picker-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
	}

	.picker-panel {
		min-width: 600rpx;
		background: #ffffff;
		border-radius: 24rpx;
		box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
		overflow: hidden;
	}

	.panel-title {
		text-align: center;
		font-size: 32rpx;
		font-weight: 500;
		color: #333;
		margin-bottom: 20rpx;
	}

	.panel-body {
		padding: 40rpx 30rpx;
	}

	.picker-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 28rpx 20rpx;
		margin: 10rpx 0;
		background: #f7f8fa;
		border-radius: 16rpx;
		font-size: 28rpx;
		color: #555;
	}

	.picker-item .val {
		color: #1677ff;
		font-weight: 500;
	}

	.btn-group {
		display: flex;
		justify-content: space-between;
		flex-direction: row;
		margin-top: 40rpx;
	}

	.btn {
		flex: 1;
		text-align: center;
		padding: 24rpx;
		border-radius: 16rpx;
		font-size: 28rpx;
		font-weight: 500;
	}

	.btn.cancel {
		background: #f5f5f5;
		color: #666;
		margin-right: 5rpx;
	}

	.btn.confirm {
		margin-left: 5rpx;
		background: #1677ff;
		color: #fff;
	}
</style>